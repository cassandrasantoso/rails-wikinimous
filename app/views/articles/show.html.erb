<h2><%= @article.title %></h2>
<p><%= @article.content %></p>
<p><%= @article.author %></p>
<p><%= @article.story %></p>

<%= link_to "Edit", edit_article_path(@article) %>

<%= link_to "Delete",
  article_path(@article),
  data: {turbo_method: :delete, turbo_confirm: "Are You Sure?"}
%>
<%= link_to "Back to Articles", articles_path %>
